# Banco
DATABASE_URL="postgresql://clinic:clinic@localhost:5432/clinic_ai"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
BETTER_AUTH_SECRET="sua-chave-secreta-minimo-32-chars"
BETTER_AUTH_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
APP_URL="exp://localhost:8081"

# IA (LLM provider: anthropic | openai | gemini)
LLM_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Firebase
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Integrações
ASAAS_WEBHOOK_TOKEN=""
ZAPI_WEBHOOK_TOKEN=""
ELEVENLABS_API_KEY=""
RESEND_API_KEY=""

# Criptografia (API keys dos clientes no banco)
ENCRYPTION_KEY=""   # 32 bytes hex: openssl rand -hex 32

# App
PORT="3001"
NODE_ENV="development"
LOG_LEVEL="info"
